# 复制此文件为 .env 并填入真实值
# Copy this file to .env and fill in real values

# DeepSeek API（通过 OpenAI SDK 调用）
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# 本地嵌入模型（首次运行会自动下载，约 570MB）
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=cpu

# HuggingFace 模型缓存目录（可选；如需避免占用默认缓存目录，可自行打开）
# HF_HOME=./.hf_cache
HF_ENDPOINT=https://hf-mirror.com

# ChromaDB 持久化目录
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION=emails

# 分块参数
CHUNK_SIZE=500
CHUNK_OVERLAP=50
MIN_CHUNK_SIZE=50

# 检索参数
TOP_K=5
VECTOR_WEIGHT=0.7
BM25_WEIGHT=0.3
RERANK_TOP_N=3

# 邮件数据路径
EMAIL_DATA_PATH=./data/emails.json

# API 服务
API_HOST=0.0.0.0
API_PORT=8000

# 前端连接的 API 地址
API_URL=http://localhost:8000

# Feature flags（默认 = V2：向量 + BM25 + RRF，业务推荐配置）
# 想跑全开 V4 配置体验消融对比，把 RERANKER 和 QUERY_REWRITE 改成 true
# 完整 6 版评测见 docs/evaluation.md
ENABLE_BM25=true
ENABLE_RRF=true
ENABLE_RERANKER=false
ENABLE_QUERY_REWRITE=false

# LLM 超时（秒）
LLM_TIMEOUT=15
